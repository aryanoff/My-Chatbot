# ─────────────────────────────────────────────
# REQUIRED — Backend (Railway env vars)
# ─────────────────────────────────────────────

# Get from https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Generate a strong random string: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-secure-random-string

# Railway auto-provides this when you add the PostgreSQL plugin
# Format: postgresql+asyncpg://user:pass@host:port/dbname
# NOTE: Railway gives postgres:// — this app auto-converts it
DATABASE_URL=postgresql+asyncpg://zaara:zaara@localhost:5432/zaara_ai

# Railway auto-provides this when you add the Redis plugin
REDIS_URL=redis://localhost:6379/0

# Comma-separated list of allowed frontend origins
# Add your Railway frontend URL and Vercel URL here
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app,https://your-frontend.railway.app

DEBUG=false

# ─────────────────────────────────────────────
# OPTIONAL — OAuth providers
# ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─────────────────────────────────────────────
# OPTIONAL — Other AI providers
# ─────────────────────────────────────────────
GEMINI_API_KEY=
OPENROUTER_API_KEY=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# ─────────────────────────────────────────────
# OPTIONAL — SMS / Notifications
# ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
FAST2SMS_API_KEY=

# ─────────────────────────────────────────────
# Frontend (.env.local in frontend/)
# On Railway: set these as build-time env vars
# On Vercel:  set in Project → Settings → Env Vars
# ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://your-backend.railway.app/api/v1
NEXT_PUBLIC_WS_URL=wss://your-backend.railway.app/api/v1
